# Copy to `.env` and fill in. `.env` is gitignored. Never commit real secrets.

# Shared enrollment secret: the control plane and the co-located agent must present the SAME value.
# Use a long random string, e.g. `openssl rand -hex 32`.
LUFF_ENROLLMENT_SECRET=

# First-boot dashboard admin. Leave these blank (the default) and the setup wizard prompts you to create your
# admin account in the browser on first visit. To provision headlessly instead, set ALL THREE together
# (username, password, and a valid email are all required); they seed an admin only while the user table is empty.
# LUFF_ADMIN_USERNAME=
# LUFF_ADMIN_PASSWORD=
# LUFF_ADMIN_EMAIL=

# Front-door address, where you reach the dashboard. One of:
#   <ip>.sslip.io   = zero-DNS name that resolves to <ip> by construction; self-signed HTTPS. Good for a VPS with no domain.
#   a bare IP       = e.g. 203.0.113.10 — served over self-signed HTTPS at https://203.0.113.10 (no domain at all).
#   a real domain   = automatic Let's Encrypt (trusted cert). Point its DNS at this box first.
# The default below is loopback, reachable only ON the box so change it on a server. Also changeable from the dashboard.
LUFF_FRONT_DOOR_DOMAIN=127.0.0.1.sslip.io

# Which published image tag to run (a release version like `1.2.3`, or `latest`). 
# Ignored in the repo, where compose.override.yaml builds the images from source instead.
LUFF_VERSION=latest

# Host directories for persistent state. Unset (the default) uses Docker-managed named volumes; the
# install script sets these so the database + keys and the TLS certificates live in a known location
# that survives updates and `docker compose down`.
# LUFF_DATA_DIR=/opt/luff/data
# LUFF_CADDY_DIR=/opt/luff/caddy
