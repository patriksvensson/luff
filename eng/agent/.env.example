# Copy to `.env` and fill in. `.env` is gitignored. The agent installer writes this for you.
#
# The agent is stateless -- all state and secrets live on the control plane. Every value below comes
# from the control plane's "Add machine" screen.

# Which published image tag to run (a release version like `1.2.3`, or `latest`).
LUFF_VERSION=latest

# A unique name for this agent host (shows up on the Machines page).
LUFF_AGENT_NAME=

# The control plane's agent-link address, e.g. https://cp.example.ts.net:8443
LUFF_SERVER_ADDRESS=

# The control plane's key pin (base64 SHA-256 of its public key).
LUFF_SERVER_PIN=

# The per-agent enrollment token (shown once when you add the machine).
LUFF_ENROLLMENT_SECRET=
