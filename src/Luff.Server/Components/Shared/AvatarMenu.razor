@inject IScopedSender Sender

<AuthorizeView>
    <Authorized>
        @{
            var first = context.User.FindFirst(ClaimTypes.GivenName)?.Value;
            var last = context.User.FindFirst(ClaimTypes.Surname)?.Value;
            var email = context.User.Identity?.Name;
            var label = TriggerName(first, last);
            var fullName = FullName(first, last);
        }
        <div class="avatarmenu @Class">
            <button class="avatar-btn" @onclick="Toggle"
                    aria-label="Account" aria-haspopup="menu" aria-expanded="@(_open ? "true" : "false")">
                <span class="avatar-badge">@Initials(first, last, email)</span>
                @if (label is not null)
                {
                    <span class="avatar-name">@label</span>
                }
                <svg class="avatar-chevron" viewBox="0 0 24 24" width="16" height="16" fill="none"
                     stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M6 9l6 6 6-6" />
                </svg>
            </button>

            @if (_open)
            {
                <div class="avatar-backdrop" @onclick="Close"></div>
                <div class="avatar-pop" role="menu">
                    <div class="avatar-pop-head">
                        <div class="avatar-pop-avatar">@Initials(first, last, email)</div>
                        <div class="avatar-pop-id">
                            <span class="avatar-pop-name">@(fullName ?? email)</span>
                            @if (fullName is not null && !string.IsNullOrEmpty(email))
                            {
                                <span class="avatar-pop-email mono">@email</span>
                            }
                            <span class="avatar-pop-role mono">@Role(context.User)</span>
                        </div>
                    </div>
                    <div class="avatar-pop-sep"></div>
                    <form method="post" action="/logout" class="avatar-pop-signout">
                        <button type="submit">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor"
                                 stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M15 5V4a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v16a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1v-1M10 12h10M17 9l3 3-3 3"/>
                            </svg>
                            Sign out
                        </button>
                    </form>
                    <div class="avatar-pop-version mono" title="Control plane version">v@_version</div>
                </div>
            }
        </div>
    </Authorized>
</AuthorizeView>

@code {
    [Parameter]
    public string? Class { get; set; }

    private bool _open;
    private string _version = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var server = await Sender.Send(new GetServerHandler.Request());
        _version = server.Version;
    }

    private void Toggle()
    {
        _open = !_open;
    }

    private void Close()
    {
        _open = false;
    }

    private static string Initials(string? first, string? last, string? email)
    {
        var f = first?.Trim();
        var l = last?.Trim();
        if (!string.IsNullOrEmpty(f) && !string.IsNullOrEmpty(l))
        {
            return $"{char.ToUpperInvariant(f[0])}{char.ToUpperInvariant(l[0])}";
        }
        if (!string.IsNullOrEmpty(f))
        {
            return char.ToUpperInvariant(f[0]).ToString();
        }
        if (!string.IsNullOrEmpty(l))
        {
            return char.ToUpperInvariant(l[0]).ToString();
        }
        return string.IsNullOrEmpty(email) ? "?" : char.ToUpperInvariant(email[0]).ToString();
    }

    private static string? TriggerName(string? first, string? last)
    {
        var f = first?.Trim();
        if (!string.IsNullOrEmpty(f))
        {
            return f;
        }
        var l = last?.Trim();
        return string.IsNullOrEmpty(l) ? null : l;
    }

    private static string? FullName(string? first, string? last)
    {
        var name = $"{first?.Trim()} {last?.Trim()}".Trim();
        return string.IsNullOrEmpty(name) ? null : name;
    }

    private static string Role(ClaimsPrincipal user)
    {
        return user.FindFirst(ClaimTypes.Role)?.Value ?? "Operator";
    }
}
