@inject IScopedSender Sender

<div class="hc">
    <p class="cfg-lede">How Luff decides a new version is ready before cutting traffic to it. Takes effect on the next deploy.</p>

    @if (_type is null)
    {
        <div class="eyebrow hc-loading">Loading...</div>
    }
    else
    {
        <div class="hc-options">
            @foreach (var option in AvailableOptions)
            {
                <button type="button" class="hc-option @(_type == option.Value ? "is-selected" : null)" @onclick="() => _type = option.Value">
                    <span class="hc-radio"></span>
                    <div class="hc-text">
                        <div class="mono hc-name">@option.Label</div>
                        <div class="hc-desc">@option.Description</div>
                    </div>
                </button>
            }
        </div>

        <div class="hc-fields">
            @if (_type == AppHealthCheckType.Http)
            {
                <label class="field hc-endpoint">
                    <span class="field-label">Endpoint</span>
                    <input class="input mono" placeholder="/health" @bind="_endpoint" />
                </label>
            }
            <label class="field hc-timeout">
                <span class="field-label">Timeout (seconds)</span>
                <input class="input mono" type="number" @bind="_timeout" />
            </label>
        </div>

        @if (_error is not null)
        {
            <div class="cfg-error">@_error</div>
        }

        <div class="hc-actions">
            <button class="btn btn-primary" @onclick="Save" disabled="@_busy">Save</button>
            @if (_saved)
            {
                <span class="hc-saved">Saved. Applies on the next deploy</span>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string App { get; set; } = string.Empty;

    private AppHealthCheckType? _type;
    private string? _endpoint;
    private int _timeout = 300;
    private bool _internal;
    private bool _busy;
    private bool _saved;
    private string? _error;

    private sealed record Option(AppHealthCheckType Value, string Label, string Description);

    private static readonly Option Docker =
        new(AppHealthCheckType.Docker, "Docker", "Uses the image's own HEALTHCHECK. Recommended default.");
    private static readonly Option Http =
        new(AppHealthCheckType.Http, "HTTP", "Poll an endpoint until it responds. Needs a tool like wget/curl in the image.");
    private static readonly Option Tcp =
        new(AppHealthCheckType.Tcp, "TCP", "The agent connects to the port until it accepts.");
    private static readonly Option None =
        new(AppHealthCheckType.None, "None", "Don't gate on readiness. A crash-looping container is still caught.");

    // Every deploy also runs a crash-loop stabilization check, so these only add readiness gating on top.
    private Option[] AvailableOptions => _internal ? [Docker, Tcp, None] : [Docker, Http, Tcp, None];

    protected override async Task OnInitializedAsync()
    {
        var app = await Sender.Send(new GetAppHandler.Request(App));
        _internal = app.Kind == AppKind.Internal;
        _type = app.HealthCheck.Type;
        _endpoint = app.HealthCheck.Endpoint;
        _timeout = app.HealthCheck.TimeoutSeconds;
    }

    private async Task Save()
    {
        _busy = true;
        _error = null;
        _saved = false;
        try
        {
            await Sender.Send(new SetHealthCheckHandler.Request(
                App, _type!.Value, _type == AppHealthCheckType.Http ? _endpoint : null, _timeout));
            _saved = true;
        }
        catch (LuffException exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
