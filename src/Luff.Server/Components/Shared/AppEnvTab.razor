@inject IScopedSender Sender

<div class="env">
    <div class="card env-note">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="5" y="11" width="14" height="9" rx="1.8" /><path d="M8 11V8a4 4 0 0 1 8 0v3" />
        </svg>
        <span>Values are encrypted and <b>write-only</b>. You set keys but never read them back; changes apply on the next deploy.</span>
    </div>

    @if (_keys is null)
    {
        <div class="eyebrow env-loading">Loading...</div>
    }
    else if (_keys.Count == 0)
    {
        <div class="cfg-empty">No environment variables set.</div>
    }
    else
    {
        <div class="env-list">
            @foreach (var key in _keys)
            {
                <div class="card env-row">
                    <span class="mono env-name">@key</span>
                    <span class="spacer"></span>
                    <span class="mono env-masked">••••••••••</span>
                    <button class="env-remove" @onclick="() => StartUnset(key)" disabled="@_busy">Unset</button>
                </div>
            }
        </div>
    }

    <div class="env-add">
        <input class="input mono env-key" placeholder="KEY" @bind="_newKey" />
        <span class="env-eq mono">=</span>
        <input class="input mono env-val" type="password" placeholder="value" @bind="_newValue" />
        <button class="btn btn-ghost env-set" @onclick="Add" disabled="@(_busy || string.IsNullOrWhiteSpace(_newKey))">Set variable</button>
    </div>

    @if (_error is not null)
    {
        <div class="cfg-error">@_error</div>
    }

    @if (_unsetting is not null)
    {
        <ConfirmDelete Name="@_unsetting" Verb="Unset" Busy="_busy" Error="@_unsetError"
                       OnConfirm="ConfirmUnset" OnClose="CancelUnset">
            Unsets <span class="mono">@_unsetting</span>. Values are write-only, so you'll have to set it again from scratch if you need it back. Applies on the next deploy.
        </ConfirmDelete>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string App { get; set; } = string.Empty;

    private IReadOnlyList<string>? _keys;
    private string _newKey = string.Empty;
    private string _newValue = string.Empty;
    private bool _busy;
    private string? _error;
    private string? _unsetting;
    private string? _unsetError;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        var vars = await Sender.Send(new ListEnvVarsHandler.Request(App));
        _keys = [.. vars.Select(variable => variable.Key)];
    }

    private async Task Add()
    {
        _busy = true;
        _error = null;
        try
        {
            await Sender.Send(new SetEnvVarHandler.Request(App, _newKey.Trim(), _newValue));
            _newKey = string.Empty;
            _newValue = string.Empty;
            await LoadAsync();
        }
        catch (LuffException exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void StartUnset(string key)
    {
        _unsetting = key;
        _unsetError = null;
    }

    private void CancelUnset()
    {
        _unsetting = null;
        _unsetError = null;
    }

    private async Task ConfirmUnset()
    {
        if (_unsetting is null)
        {
            return;
        }

        _busy = true;
        _unsetError = null;
        try
        {
            await Sender.Send(new UnsetEnvVarHandler.Request(App, _unsetting));
            _unsetting = null;
            await LoadAsync();
        }
        catch (LuffException exception)
        {
            _unsetError = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
