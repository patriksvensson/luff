<span class="badge @_class">
    @if (_warn)
    {
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3.6 2.4 20.2h19.2z" />
            <path d="M12 10v4.2" />
            <path d="M12 17.4h.01" />
        </svg>
    }
    else
    {
        <span class="dot @_icon"></span>
    }
    <span>@_text</span>
</span>

@code {
    [Parameter, EditorRequired]
    public AppHealthState State { get; set; }

    [Parameter]
    public string? Detail { get; set; }

    private string _class = string.Empty;
    private string _icon = string.Empty;
    private string _text = string.Empty;
    private bool _warn;

    protected override void OnParametersSet()
    {
        (_class, _icon, _text, _warn) = State switch
        {
            AppHealthState.Live => ("badge-green", "dot-green", "Live", false),
            AppHealthState.Deploying => ("badge-amber", "dot-amber", Compose("Deploying"), false),
            AppHealthState.Drift => ("badge-amber", "", Compose("Drift"), true),
            AppHealthState.Failed => ("badge-red", "dot-red", "Deploy failed", false),
            AppHealthState.Unhealthy => ("badge-red", "", Compose("Unhealthy"), true),
            AppHealthState.Stopped => ("badge-neutral", "dot-neutral", "Stopped", false),
            _ => ("badge-neutral", "dot-neutral", Compose("Dormant"), false),
        };
    }

    private string Compose(string label) =>
        string.IsNullOrEmpty(Detail) ? label : $"{label} | {Detail}";
}
