<div class="activity">
    @if (Detail.Deployments.Count == 0)
    {
        <div class="card activity-empty">No deployments yet.</div>
    }
    else
    {
        <div class="activity-list">
            @foreach (var deployment in Detail.Deployments)
            {
                <div class="card activity-card">
                    <div class="activity-top">
                        <span class="dot @DeployDot(deployment)"></span>
                        <span class="mono activity-tag">@deployment.Tag</span>
                        <span class="spacer"></span>
                        <span class="activity-when">@deployment.When</span>
                    </div>
                    <div class="activity-foot">
                        <span class="spacer"></span>
                        <span class="mono activity-status @StatusClass(deployment)">@StatusText(deployment)</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public AppDetail Detail { get; set; } = null!;

    private static string DeployDot(AppDeploymentLine deployment)
    {
        return deployment.Failed ? "dot-red" : deployment.Succeeded ? "dot-green" : "dot-amber";
    }

    private static string StatusClass(AppDeploymentLine deployment)
    {
        return deployment.Failed ? "is-failed" : deployment.Succeeded ? "is-ok" : "is-progress";
    }

    private static string StatusText(AppDeploymentLine deployment)
    {
        return deployment.Failed && deployment.FailureReason is not null
            ? $"{deployment.Status} | {deployment.FailureReason}"
            : deployment.Status;
    }

}
