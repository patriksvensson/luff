@inject IScopedSender Sender
@inject NavigationManager Navigation
@inject TimeProvider Time
@inject IJSRuntime JS

<div class="wh">
    <p class="cfg-lede">Let CI trigger a deploy by calling this webhook after it pushes an image</p>

    <div class="card wh-warn">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3.6 2.4 20.2h19.2z" /><path d="M12 10v4.2" /><path d="M12 17.4h.01" />
        </svg>
        <span>The token is shown <b>once</b> at creation and never again. Copy it when you make it.</span>
    </div>

    <div class="wh-form">
        <input class="input wh-name-input" @bind="_name" @bind:event="oninput" placeholder="Name, e.g. github-actions" />
        <button class="btn btn-ghost wh-create" @onclick="Create" disabled="@(_busy || string.IsNullOrWhiteSpace(_name))">+ Create webhook token</button>
    </div>

    @if (_created is not null)
    {
        <div class="wh-reveal">
            <div class="eyebrow">Webhook URL | @_created.Name</div>
            <div class="wh-url-field">
                <span class="mono wh-url">@WebhookUrl(_created.Token)</span>
                <button class="wh-copy" @onclick="() => Copy(WebhookUrl(_created.Token))" title="Copy URL" aria-label="Copy webhook URL">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="9" y="9" width="11" height="11" rx="2" /><path d="M5 15V5a2 2 0 0 1 2-2h10" />
                    </svg>
                </button>
            </div>
        </div>
    }

    @if (_error is not null)
    {
        <div class="cfg-error">@_error</div>
    }

    @if (_tokens is null)
    {
        <div class="eyebrow wh-loading">Loading...</div>
    }
    else if (_tokens.Count == 0)
    {
        <div class="cfg-empty">No webhook tokens yet.</div>
    }
    else
    {
        <div class="wh-list">
            @foreach (var token in _tokens)
            {
                <div class="card wh-row">
                    <div class="wh-ident">
                        <span class="wh-name">@(string.IsNullOrEmpty(token.Name) ? "unnamed" : token.Name)</span>
                        <span class="wh-meta">
                            <span class="mono wh-id">@token.Id.ToString()[..8]</span>
                            | Created @Rel(token.CreatedAt)
                            @(token.LastUsedAt is null ? "| Never used" : $"| Last used {Rel(token.LastUsedAt.Value)}")
                        </span>
                    </div>
                    <span class="spacer"></span>
                    <button class="wh-revoke" @onclick="() => StartRevoke(token)" disabled="@_busy">Revoke</button>
                </div>
            }
        </div>
    }

    <div class="wh-snippet">
        <div class="eyebrow">CI snippet</div>
        <pre class="mono card wh-code"><span class="wh-comment"># After your build pushes the image</span>
curl -X POST "$LUFF_WEBHOOK" \
  -H "Content-Type: application/json" \
  -d '@("{" + "\"tag\":\"v1.4.4\"" + "}")'</pre>
    </div>

    @if (_revoking is { } revoke)
    {
        <ConfirmDelete Name="@revoke.Name" Verb="Revoke" Busy="_busy" Error="@_revokeError"
                       OnConfirm="ConfirmRevoke" OnClose="CancelRevoke">
            Revokes <span class="mono">@revoke.Name</span>. Any CI still calling this webhook gets a 401 until you create a new token. This can't be undone.
        </ConfirmDelete>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string App { get; set; } = string.Empty;

    private IReadOnlyList<TokenResponse>? _tokens;
    private CreateTokenResponse? _created;
    private string _name = string.Empty;
    private bool _busy;
    private string? _error;
    private (Guid Id, string Name)? _revoking;
    private string? _revokeError;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync() =>
        _tokens = await Sender.Send(new ListWebhookTokensHandler.Request(App));

    private async Task Create()
    {
        _busy = true;
        _error = null;
        try
        {
            _created = await Sender.Send(new CreateWebhookTokenHandler.Request(App, _name.Trim()));
            _name = string.Empty;
            await LoadAsync();
        }
        catch (LuffException exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void StartRevoke(TokenResponse token)
    {
        _revoking = (token.Id, string.IsNullOrEmpty(token.Name) ? token.Id.ToString()[..8] : token.Name);
        _revokeError = null;
    }

    private void CancelRevoke()
    {
        _revoking = null;
        _revokeError = null;
    }

    private async Task ConfirmRevoke()
    {
        if (_revoking is not { } revoke)
        {
            return;
        }

        _busy = true;
        _revokeError = null;
        try
        {
            await Sender.Send(new RevokeWebhookTokenHandler.Request(App, revoke.Id));
            if (_created?.Id == revoke.Id)
            {
                _created = null;
            }

            _revoking = null;
            await LoadAsync();
        }
        catch (LuffException exception)
        {
            _revokeError = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private string WebhookUrl(string token) => $"{Navigation.BaseUri}webhook/{token}";

    private async Task Copy(string text) => await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);

    private string Rel(DateTimeOffset at) => AppHealth.Relative(Time.GetUtcNow() - at);
}
