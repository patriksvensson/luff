<div class="page-head">
    <h1 class="page-title">@Title</h1>
</div>

<div class="placeholder">
    <div class="placeholder-icon">
        <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3.6 4.5 7.8v8.4L12 20.4l7.5-4.2V7.8z" />
            <path d="M4.7 7.9 12 12l7.3-4.1M12 12v8.4" />
        </svg>
    </div>
    <p class="placeholder-title">@Title isn’t built yet</p>
    <p class="placeholder-note">@Note</p>
</div>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Note { get; set; } = "This section arrives in a later slice.";
}
