@inject IScopedSender Sender
@inject NavigationManager Navigation

<div class="settings">
    @if (_image is null)
    {
        <div class="eyebrow settings-loading">Loading...</div>
    }
    else
    {
        <div class="card settings-config">
            <div class="eyebrow">Configuration</div>
            <div class="settings-grid">
                <label class="field">
                    <span class="field-label">Image</span>
                    <input class="input mono" @bind="_image" />
                </label>
                @if (!_frontless)
                {
                    <label class="field">
                        <span class="field-label">Domain</span>
                        <input class="input mono" @bind="_domain" />
                    </label>
                }
                <label class="field settings-port">
                    <span class="field-label">@PortLabel</span>
                    <input class="input mono" type="number" @bind="_port" />
                </label>
            </div>

            @if (!_frontless)
            {
                <div class="field settings-tls">
                    <span class="field-label">TLS termination</span>
                    <div class="tls-modes">
                        <button type="button" class="tls-mode @(_tlsMode == TlsMode.Managed ? "is-active" : null)"
                                @onclick='() => _tlsMode = TlsMode.Managed'>
                            <span class="tls-mode-name">Managed</span>
                            <span class="tls-mode-desc">Luff obtains the certificate automatically</span>
                        </button>
                        <button type="button" class="tls-mode @(_tlsMode == TlsMode.External ? "is-active" : null)"
                                @onclick='() => _tlsMode = TlsMode.External'>
                            <span class="tls-mode-name">External</span>
                            <span class="tls-mode-desc">A load balancer in front terminates TLS</span>
                        </button>
                    </div>
                    <p class="tls-served">@ServedScheme</p>
                </div>
            }

            <p class="settings-note">
                @if (_direct)
                {
                    <text>Publish host ports on the Ports tab. Image and container port apply on the next deploy (in place, brief downtime).</text>
                }
                else if (_internal)
                {
                    <text>Reachable by sibling apps as <span class="mono">@App:@_port</span>. Image and port apply on the next deploy.</text>
                }
                else
                {
                    <text>Domain and TLS changes take effect <b>immediately</b>. Traffic re-points live. Image and port apply on the next deploy.</text>
                }
            </p>
            @if (_error is not null)
            {
                <div class="cfg-error">@_error</div>
            }
            <div class="settings-actions">
                <button class="btn btn-primary" @onclick="Save" disabled="@_busy">Save</button>
                @if (_saved)
                {
                    <span class="settings-saved">Saved</span>
                }
            </div>
        </div>

        @if (!_frontless)
        {
            <div class="card settings-config">
                <div class="eyebrow">Basic authentication</div>
                <div class="settings-grid">
                    <label class="field">
                        <span class="field-label">Username</span>
                        <input class="input mono" autocomplete="off" @bind="_authUsername" />
                    </label>
                    <div class="field">
                        <span class="field-label">Password</span>
                        <SecretField @bind-Value="_authPassword" Placeholder="password" />
                    </div>
                </div>
                <p class="settings-note">
                    Gate this app behind an HTTP basic-auth prompt at the proxy. Only the hashed credential reaches
                    the agent, and changes take effect <b>immediately</b>.
                </p>
                @if (_authError is not null)
                {
                    <div class="cfg-error">@_authError</div>
                }
                <div class="settings-actions">
                    <button class="btn btn-primary" @onclick="SaveBasicAuth" disabled="@_authBusy">
                        @(_authConfigured ? "Update" : "Enable")
                    </button>
                    @if (_authConfigured)
                    {
                        <button class="btn btn-ghost" @onclick="StartClearAuth" disabled="@_authBusy">Remove</button>
                    }
                    @if (_authSaved)
                    {
                        <span class="settings-saved">Saved</span>
                    }
                </div>
            </div>
        }

        <div class="card danger">
            <div class="eyebrow danger-label">Danger zone</div>
            <div class="danger-row">
                <span class="danger-text">Delete this app and its config. Running containers are left to drain.</span>
                <button class="btn btn-danger" @onclick="StartDelete">Delete app</button>
            </div>
        </div>
    }
</div>

@if (_confirming)
{
    <ConfirmDelete Name="@App" Verb="Delete" Busy="_busy" Error="@_deleteError"
                   OnConfirm="Delete" OnClose="CancelDelete">
        Deletes <span class="mono">@App</span> and its config. Running containers are left to drain. This can't be undone.
    </ConfirmDelete>
}

@if (_clearingAuth)
{
    <ConfirmDelete Name="@App" Verb="Disable" Title="Disable basic authentication?" Busy="_authBusy"
                   Error="@_clearAuthError" OnConfirm="ClearBasicAuth" OnClose="CancelClearAuth">
        Removes the basic-auth gate from <span class="mono">@App</span>. Anyone who can reach the domain is no longer prompted. Applies immediately.
    </ConfirmDelete>
}

@code {
    [Parameter, EditorRequired]
    public string App { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private string? _image;
    private bool _internal;
    private bool _direct;
    private bool _frontless => _internal || _direct;
    private string _domain = string.Empty;
    private int _port;
    private TlsMode _tlsMode = TlsMode.Managed;
    private bool _busy;
    private bool _saved;
    private bool _confirming;
    private string? _deleteError;
    private string? _error;
    private string _actor = Actors.System;

    private bool _authConfigured;
    private string _authUsername = string.Empty;
    private string _authPassword = string.Empty;
    private bool _authBusy;
    private bool _authSaved;
    private string? _authError;
    private bool _clearingAuth;
    private string? _clearAuthError;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private string PortLabel => _frontless ? (_direct ? "Container port" : "Service port") : "Internal port";

    private string ServedScheme => _tlsMode == TlsMode.External
        ? "Serves HTTP on :80. TLS is terminated by your load balancer."
        : AppHealth.IsAutoDomain(_domain)
            ? "Serves HTTP on :80. sslip.io default domains are plain HTTP."
            : "Serves HTTPS on :443. A Let's Encrypt certificate is obtained automatically.";

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _actor = state.User.Identity?.Name ?? Actors.System;
        }

        var app = await Sender.Send(new GetAppHandler.Request(App));
        _image = app.Image;
        _internal = app.Kind == AppKind.Internal;
        _direct = app.Kind == AppKind.Direct;
        _domain = app.Domain ?? string.Empty;
        _port = app.InternalPort;
        _tlsMode = app.TlsMode;

        if (!_frontless)
        {
            var basicAuth = await Sender.Send(new GetBasicAuthHandler.Request(App));
            _authConfigured = basicAuth.Configured;
            _authUsername = basicAuth.Username ?? string.Empty;
            _authPassword = basicAuth.Password ?? string.Empty;
        }
    }

    private async Task Save()
    {
        _busy = true;
        _error = null;
        _saved = false;
        try
        {
            await Sender.Send(new UpdateAppHandler.Request(
                App, _image!, _port, _actor,
                domain: _frontless ? null : _domain.Trim(),
                tlsMode: _frontless ? null : _tlsMode));
            _saved = true;
            await OnChanged.InvokeAsync();
        }
        catch (LuffException exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void StartDelete()
    {
        _deleteError = null;
        _confirming = true;
    }

    private void CancelDelete()
    {
        _confirming = false;
        _deleteError = null;
    }

    private async Task Delete()
    {
        _busy = true;
        _deleteError = null;
        try
        {
            await Sender.Send(new DeleteAppHandler.Request(App, _actor));
            Navigation.NavigateTo("apps");
        }
        catch (LuffException exception)
        {
            _deleteError = exception.Message;
            _busy = false;
        }
    }

    private async Task SaveBasicAuth()
    {
        _authBusy = true;
        _authError = null;
        _authSaved = false;
        try
        {
            await Sender.Send(new SetBasicAuthHandler.Request(App, _authUsername, _authPassword, _actor));
            _authConfigured = true;
            _authSaved = true;
        }
        catch (LuffException exception)
        {
            _authError = exception.Message;
        }
        finally
        {
            _authBusy = false;
        }
    }

    private void StartClearAuth()
    {
        _clearAuthError = null;
        _clearingAuth = true;
    }

    private void CancelClearAuth()
    {
        _clearingAuth = false;
        _clearAuthError = null;
    }

    private async Task ClearBasicAuth()
    {
        _authBusy = true;
        _clearAuthError = null;
        try
        {
            await Sender.Send(new ClearBasicAuthHandler.Request(App, _actor));
            _clearingAuth = false;
            _authConfigured = false;
            _authUsername = string.Empty;
            _authPassword = string.Empty;
            _authSaved = false;
            _authError = null;
        }
        catch (LuffException exception)
        {
            _clearAuthError = exception.Message;
        }
        finally
        {
            _authBusy = false;
        }
    }
}
