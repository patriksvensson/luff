<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>Luff</title>
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="favicon-32.png" />
    <link rel="icon" href="favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="apple-touch-icon.png" />
    <link rel="stylesheet" href="fonts/fonts.css" />
    <link rel="stylesheet" href="css/tokens.css?v=@Version" />
    <link rel="stylesheet" href="css/app.css?v=@Version" />
    <link rel="stylesheet" href="Luff.Server.styles.css?v=@Version" />
    <HeadOutlet @rendermode="PageRenderMode" />
</head>
<body>
    <Routes @rendermode="PageRenderMode" />

    <div id="components-reconnect-modal">
        <div class="reconnect-card">
            <div class="reconnect-spinner" aria-hidden="true"></div>
            <p class="reconnect-msg reconnect-msg-show">Reconnecting to the server...</p>
            <p class="reconnect-msg reconnect-msg-failed">
                Couldn't reconnect. <button type="button" class="reconnect-btn" onclick="Blazor.reconnect()">Retry</button>
            </p>
            <p class="reconnect-msg reconnect-msg-rejected">
                The session expired. <button type="button" class="reconnect-btn" onclick="location.reload()">Reload</button>
            </p>
        </div>
    </div>

    <script src="_framework/blazor.web.js"></script>
</body>
</html>

@code {
    private static readonly string Version = DateTimeOffset.UtcNow.Ticks.ToString("x");

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = null!;

    private IComponentRenderMode? PageRenderMode =>
        HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;
}
