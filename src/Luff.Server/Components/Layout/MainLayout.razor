@inherits LayoutComponentBase
@inject IScopedSender Sender

<div class="layout">
    <aside class="sidebar">
        <div class="brand">
            <svg class="brand-mark" viewBox="0 0 24 24" width="24" height="24" fill="none" aria-hidden="true">
                <path d="M12.8 3.2 4.6 15.6c-.4.6 0 1.4.8 1.4h7.4V3.6c0-.8-1-.9-1.4-.4z" fill="var(--green)" />
                <path d="M15 17h4.2c.8 0 1.2.9.7 1.5l-1.5 1.9c-.2.2-.4.3-.7.3H10"
                      stroke="var(--green)" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span class="brand-name">Luff</span>
        </div>

        <nav class="nav">
            <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3.5" y="3.5" width="7" height="7" rx="1.6" /><rect x="13.5" y="3.5" width="7" height="7" rx="1.6" />
                    <rect x="3.5" y="13.5" width="7" height="7" rx="1.6" /><rect x="13.5" y="13.5" width="7" height="7" rx="1.6" />
                </svg>
                <span>Apps</span>
            </NavLink>
            <NavLink class="nav-item" href="machines">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3.5" y="4.5" width="17" height="6" rx="1.7" /><rect x="3.5" y="13" width="17" height="6" rx="1.7" />
                    <path d="M7 7.5h.01M7 16h.01" />
                </svg>
                <span>Machines</span>
            </NavLink>
            <NavLink class="nav-item" href="activity">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 12h4l2.4-6.5L13.6 18l2.4-6h5" />
                </svg>
                <span>Activity</span>
            </NavLink>
            <NavLink class="nav-item" href="registries">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3.3l7.5 4.35v8.7L12 20.7 4.5 16.35v-8.7z" />
                </svg>
                <span>Registries</span>
            </NavLink>
            <NavLink class="nav-item" href="settings">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="3.2" />
                    <path d="M12 2.6v3M12 18.4v3M2.6 12h3M18.4 12h3M5.4 5.4l2.1 2.1M16.5 16.5l2.1 2.1M18.6 5.4l-2.1 2.1M7.5 16.5l-2.1 2.1" />
                </svg>
                <span>Settings</span>
            </NavLink>
        </nav>

        <div class="sidebar-foot">
            <a class="tls-chip @(_autoDomain ? "tls-chip-warn" : "tls-chip-ok")" href="settings" title="@_tlsTitle">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="4.5" y="10.5" width="15" height="10" rx="2" />
                    <path d="M8 10.5V7.5a4 4 0 0 1 8 0v3" />
                </svg>
                <span class="tls-chip-text">@(_autoDomain ? "Self-signed" : "Trusted")</span>
            </a>
            <AuthorizeView>
                <Authorized>
                    <div class="user-card">
                        <div class="user-avatar">@Initial(context.User.Identity?.Name)</div>
                        <div class="user-meta">
                            <span class="user-name">@context.User.Identity?.Name</span>
                            <span class="user-role mono">@Role(context.User)</span>
                        </div>
                        <form method="post" action="logout" class="user-signout">
                            <button type="submit" title="Sign out" aria-label="Sign out">
                                <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M15 5V4a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v16a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1v-1M10 12h10M17 9l3 3-3 3" />
                                </svg>
                            </button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    <main class="content">
        @Body
    </main>
</div>

@code {
    private bool _autoDomain = true;
    private string _tlsTitle = "Front-door certificate";

    protected override async Task OnInitializedAsync()
    {
        var server = await Sender.Send(new GetServerHandler.Request());
        _autoDomain = AppHealth.IsAutoDomain(server.FrontDoorDomain);
        _tlsTitle = _autoDomain
            ? $"{server.FrontDoorDomain} · self-signed certificate — encrypted, one-time browser warning"
            : $"{server.FrontDoorDomain} · publicly trusted certificate";
    }

    private static string Initial(string? name) =>
        string.IsNullOrEmpty(name) ? "?" : name[..1].ToUpperInvariant();

    private static string Role(ClaimsPrincipal user) =>
        user.FindFirst(ClaimTypes.Role)?.Value ?? "Operator";
}
