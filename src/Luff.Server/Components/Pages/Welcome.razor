@page "/welcome"
@attribute [Authorize]
@layout EmptyLayout
@inject IScopedSender Sender
@inject NavigationManager Navigation

<PageTitle>Welcome - Luff</PageTitle>

<div class="welcome">
    <div class="welcome-card">
        <div class="welcome-brand">
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" aria-hidden="true">
                <path d="M12.8 3.2 4.6 15.6c-.4.6 0 1.4.8 1.4h7.4V3.6c0-.8-1-.9-1.4-.4z" fill="var(--green)" />
                <path d="M15 17h4.2c.8 0 1.2.9.7 1.5l-1.5 1.9c-.2.2-.4.3-.7.3H10"
                      stroke="var(--green)" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Luff</span>
        </div>

        <h1 class="welcome-title">Welcome to Luff</h1>
        <p class="welcome-sub">You're signed in with the bootstrap password. Set your own to finish setting up.</p>

        <label class="field">
            <span class="field-label">Current password</span>
            <input class="input" type="password" @bind="_current" @bind:event="oninput" autocomplete="current-password" />
        </label>
        <label class="field">
            <span class="field-label">New password</span>
            <input class="input" type="password" @bind="_new" @bind:event="oninput" autocomplete="new-password" />
        </label>
        <label class="field">
            <span class="field-label">Confirm new password</span>
            <input class="input" type="password" @bind="_confirm" @bind:event="oninput" autocomplete="new-password" />
        </label>

        @if (Mismatch)
        {
            <div class="welcome-error">Passwords don't match.</div>
        }
        else if (_error is not null)
        {
            <div class="welcome-error">@_error</div>
        }

        <button class="btn btn-primary welcome-submit" @onclick="Save"
                disabled="@(_busy || string.IsNullOrEmpty(_current) || string.IsNullOrEmpty(_new) || _new != _confirm)">Set password</button>

        <a class="welcome-skip" href="apps">Skip for now</a>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private string _username = string.Empty;
    private string _current = string.Empty;
    private string _new = string.Empty;
    private string _confirm = string.Empty;
    private bool _busy;
    private string? _error;

    private bool Mismatch => !string.IsNullOrEmpty(_confirm) && _new != _confirm;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _username = state.User.Identity?.Name ?? string.Empty;
        }
    }

    private async Task Save()
    {
        _busy = true;
        _error = null;
        try
        {
            await Sender.Send(new ChangePasswordHandler.Request(_username, _current, _new));
            Navigation.NavigateTo("apps");
        }
        catch (LuffException)
        {
            _error = "That current password isn't right.";
        }
        finally
        {
            _busy = false;
        }
    }
}
