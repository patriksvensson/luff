@page "/settings"
@page "/settings/{Tab}"
@attribute [Authorize]

<PageTitle>Settings - Luff</PageTitle>

<div class="page-head">
    <BrandMark class="mobile-only" />
    <h1 class="page-title">Settings</h1>
    <span class="spacer"></span>
    <AvatarMenu />
</div>

@if (!_ready)
{
    <div class="eyebrow set-loading">Loading...</div>
}
else
{
    <nav class="tabs">
        <NavLink class="tab" href="settings" Match="NavLinkMatch.All">Account</NavLink>
        @if (_isAdmin)
        {
            <NavLink class="tab" href="settings/server">Server</NavLink>
            <NavLink class="tab" href="settings/users">Users</NavLink>
            <NavLink class="tab" href="settings/notifications">Notifications</NavLink>
        }
    </nav>

    <div class="set-body">
        @switch (ActiveTab)
        {
            case "server":
                <SettingsServerTab />
                break;
            case "users":
                <SettingsUsersTab />
                break;
            case "notifications":
                <SettingsNotificationsTab />
                break;
            default:
                <SettingsAccountTab />
                break;
        }
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    [Parameter]
    public string? Tab { get; set; }

    private bool _isAdmin;
    private bool _ready;

    private string ActiveTab => _isAdmin
        ? Tab?.ToLowerInvariant() switch
        {
            "server" => "server",
            "users" => "users",
            "notifications" => "notifications",
            _ => "account",
        }
        : "account";

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _isAdmin = state.User.IsInRole("Admin");
        }

        _ready = true;
    }
}
