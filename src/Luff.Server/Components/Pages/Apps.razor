@page "/"
@page "/apps"
@attribute [Authorize]
@inject IScopedSender Sender
@inject NavigationManager Navigation

<PageTitle>Apps - Luff</PageTitle>

<div class="page-head">
    <BrandMark class="mobile-only" />
    <h1 class="page-title">Apps</h1>
    <div class="spacer"></div>
    <button class="btn btn-primary btn-add" @onclick="StartCreate" aria-label="Add app">
        <svg class="mobile-only" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
        <span class="desktop-only">Add app</span>
    </button>
    <AvatarMenu />
</div>

@if (_overview is null)
{
    <div class="apps-meta eyebrow">Loading...</div>
}
else if (_overview.Apps.Count == 0)
{
    <div class="apps-empty">
        <div class="apps-empty-title">No apps yet</div>
        <p class="apps-empty-note">Create your first app to point Luff at a container image and a domain.</p>
        <button class="btn btn-primary" @onclick="StartCreate">Add app</button>
    </div>
}
else
{
    <div class="apps-meta">
        <span class="eyebrow apps-summary">
            <span>@_overview.Apps.Count @Pluralize(_overview.Apps.Count, "app")</span>
            <span class="sep">|</span>
            <span>@_overview.MachineCount @Pluralize(_overview.MachineCount, "machine")</span>
            @if (_overview.MachineCount > 0)
            {
                <span class="sep">|</span>
                <span class="@(_overview.AllConnected ? "ok" : "warn")">@(_overview.AllConnected ? "all connected" : "check fleet")</span>
            }
        </span>
        @if (_overview.DeployingCount > 0)
        {
            <span class="chip chip-amber">
                <span class="dot dot-amber"></span>
                @_overview.DeployingCount deploying
            </span>
        }
    </div>

    <div class="app-list">
        @foreach (var app in _overview.Apps)
        {
            var action = Action(app.State);
            var domainUrl = (app.Https ? "https://" : "http://") + app.Domain;
            <div class="app-card @CardStateClass(app.State)">
                <div class="app-card-head">
                    <div class="app-ident">
                        <div class="app-ident-top">
                            <a class="app-name" href="apps/@app.Name">@app.Name</a>
                            @if (app.Internal)
                            {
                                <span class="chip">internal</span>
                            }
                            else if (app.Direct)
                            {
                                <span class="chip">direct</span>
                            }
                            else if (app.AutoDomain)
                            {
                                <span class="chip">auto domain</span>
                            }
                            else
                            {
                                <a class="app-domain link" href="@domainUrl" target="_blank" rel="noopener">@app.Domain ↗</a>
                            }
                        </div>
                        <div class="app-sub mono">
                            @if (app.Internal)
                            {
                                @app.InternalHost
                            }
                            else if (app.Direct)
                            {
                                @app.Image
                            }
                            else if (app.AutoDomain)
                            {
                                <a class="link" href="http://@app.Domain" target="_blank" rel="noopener">@app.Domain ↗</a>
                            }
                            else
                            {
                                @app.Image
                            }
                        </div>
                    </div>

                    <div class="app-meta-right">
                        @if (app.CurrentTag is not null)
                        {
                            <span class="app-tag mono">@app.CurrentTag</span>
                            @if (app.MachineCount > 0)
                            {
                                <span class="app-submeta">@app.MachineCount @Pluralize(app.MachineCount, "machine") | @app.LastDeploy</span>
                            }
                        }
                        else
                        {
                            <span class="app-neverdeployed">never deployed</span>
                        }
                    </div>
                </div>

                <div class="app-card-foot">
                    <StatusBadge State="app.State" Detail="@app.StateDetail" />
                    <a class="btn @(action.Primary ? "btn-primary" : "btn-ghost") btn-sm app-action" href="@ActionHref(app)">@action.Label</a>
                </div>
            </div>
        }
    </div>
}

@if (_creating)
{
    <Modal Width="md" OnClose="CloseCreate">
        <div class="new-app">
            <div class="new-app-head">
                <h2 class="new-app-title">New app</h2>
                <button class="pipe-close" @onclick="CloseCreate" aria-label="Close">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="m6 6 12 12M18 6 6 18" /></svg>
                </button>
            </div>

            <p class="new-app-lede">Point Luff at a container image. It runs nowhere until you attach it to a machine.</p>

            <label class="field">
                <span class="field-label">Name</span>
                <input class="input mono" @bind="_name" @bind:event="oninput" placeholder="@(Direct ? "e.g. grafana" : Internal ? "e.g. postgres" : "e.g. web")" />
            </label>

            <label class="field">
                <span class="field-label">Type</span>
                <select class="input" @bind="_kind">
                    <option value="Web">Web app: public, fronted by Caddy with a domain</option>
                    <option value="Internal">Internal service: private, reachable only by sibling apps</option>
                    <option value="Direct">Direct: private, reached on published host ports (tailnet / LAN)</option>
                </select>
            </label>

            <label class="field">
                <span class="field-label">Image</span>
                <input class="input mono" @bind="_image" @bind:event="oninput" placeholder="@(Direct ? "grafana/grafana" : Internal ? "postgres" : "ghcr.io/acme/web")" />
            </label>

            @if (!Frontless)
            {
                <label class="field">
                    <span class="field-label">Domain</span>
                    <input class="input mono" @bind="_domain" @bind:event="oninput" placeholder="web.example.com" />
                </label>

                <div class="field-row">
                    <label class="field field-port">
                        <span class="field-label">Internal port</span>
                        <input class="input mono" type="number" min="1" max="65535" @bind="_port" @bind:event="oninput" />
                    </label>
                    <label class="field field-tls">
                        <span class="field-label">TLS</span>
                        <select class="input mono" @bind="_tlsMode">
                            <option value="Managed">Managed (Let's Encrypt)</option>
                            <option value="External">External terminator</option>
                        </select>
                    </label>
                </div>
            }
            else
            {
                <label class="field field-port">
                    <span class="field-label">@(Direct ? "Container port" : "Service port")</span>
                    <input class="input mono" type="number" min="1" max="65535" @bind="_port" @bind:event="oninput" placeholder="e.g. @(Direct ? "3000" : "5432")" />
                </label>

                @if (Direct)
                {
                    <p class="new-app-hint">
                        Reached on published host ports, which you add on its <b>Ports</b> tab after creating.
                        Front those ports over your tailnet or LAN yourself (e.g. <span class="mono">tailscale serve</span>).
                        Deploys recreate it in place (brief downtime).
                    </p>
                }
                else
                {
                    <p class="new-app-hint">
                        Sibling apps on the same machine reach it as
                        <span class="mono">@(_name.Length == 0 ? "name" : _name):@(_port.Length == 0 ? "port" : _port)</span>.
                        Add a volume on its Volumes tab to persist data. Deploys recreate it in place (brief downtime).
                    </p>
                }
            }

            @if (_error is not null)
            {
                <div class="cfg-error">@_error</div>
            }

            <div class="confirm-actions">
                <button class="btn btn-ghost" @onclick="CloseCreate">Cancel</button>
                <button class="btn btn-primary" @onclick="Create" disabled="@(_busy || !CanCreate)">Create app</button>
            </div>
        </div>
    </Modal>
}

@code {
    private AppsOverview? _overview;

    private bool _creating;
    private string _name = string.Empty;
    private AppKind _kind = AppKind.Web;
    private string _image = string.Empty;
    private string _domain = string.Empty;
    private string _port = "8080";
    private TlsMode _tlsMode = TlsMode.Managed;
    private bool _busy;
    private string? _error;

    private bool Internal => _kind == AppKind.Internal;
    private bool Direct => _kind == AppKind.Direct;
    private bool Frontless => _kind != AppKind.Web;

    private bool CanCreate =>
        !string.IsNullOrWhiteSpace(_name)
        && !string.IsNullOrWhiteSpace(_image)
        && (Frontless || !string.IsNullOrWhiteSpace(_domain))
        && int.TryParse(_port, out var port) && port is >= 1 and <= 65535;

    protected override async Task OnInitializedAsync()
    {
        _overview = await Sender.Send(new AppsOverviewHandler.Request());
    }

    private static string? CardStateClass(AppHealthState state) => state switch
    {
        AppHealthState.Deploying => "is-deploying",
        AppHealthState.Dormant => "is-dormant",
        _ => null,
    };

    private static (string Label, bool Primary) Action(AppHealthState state) => state switch
    {
        AppHealthState.Dormant => ("Attach to a machine", true),
        AppHealthState.Deploying => ("Watch", false),
        AppHealthState.Stopped => ("Start", true),
        AppHealthState.Unhealthy => ("View", false),
        _ => ("Deploy", false),
    };

    private static string ActionHref(AppOverviewRow app) => app.State switch
    {
        AppHealthState.Deploying or AppHealthState.Dormant
            or AppHealthState.Stopped or AppHealthState.Unhealthy => $"apps/{app.Name}",
        _ => $"apps/{app.Name}?deploy=true",
    };

    private static string Pluralize(int count, string noun)
    {
        return count == 1 ? noun : noun + "s";
    }

    private void StartCreate()
    {
        _name = string.Empty;
        _kind = AppKind.Web;
        _image = string.Empty;
        _domain = string.Empty;
        _port = "8080";
        _tlsMode = TlsMode.Managed;
        _error = null;
        _creating = true;
    }

    private void CloseCreate()
    {
        _creating = false;
    }

    private async Task Create()
    {
        if (!CanCreate)
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var created = await Sender.Send(new CreateAppHandler.Request(
                _name.Trim(), _image.Trim(), int.Parse(_port),
                kind: _kind,
                domain: Frontless ? null : _domain.Trim(),
                tlsMode: Frontless ? null : _tlsMode));
            Navigation.NavigateTo($"apps/{created.Name}");
        }
        catch (LuffException exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
