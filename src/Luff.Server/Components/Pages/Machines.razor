@page "/machines"
@attribute [Authorize]
@implements IDisposable
@inject IScopedSender Sender
@inject IFleetEvents Fleet
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject Microsoft.Extensions.Options.IOptions<InstallerOptions> Installer

<PageTitle>Machines - Luff</PageTitle>

<div class="page-head">
    <BrandMark class="mobile-only" />
    <h1 class="page-title">Machines</h1>
    @if (_fleet is { Count: > 0 } fleet)
    {
        <span class="chip">@fleet.Count @(fleet.Count == 1 ? "host" : "hosts")</span>
    }

    <span class="spacer"></span>
    @if (_isAdmin)
    {
        <button class="btn btn-primary btn-add" @onclick="StartEnroll" aria-label="Add machine">
            <svg class="mobile-only" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
            <span class="desktop-only">Add machine</span>
        </button>
    }
    <AvatarMenu />
</div>

@if (_fleet is null)
{
    <div class="eyebrow fleet-loading">Loading...</div>
}
else if (_fleet.Count == 0)
{
    <div class="cfg-empty">No machines enrolled yet.@(_isAdmin ? " Add one to start deploying." : "")</div>
}
else
{
    <div class="fleet">
        @foreach (var machine in _fleet)
        {
            <div class="card fleet-card @CardClass(machine.Status)">
                <div class="fleet-top">
                    <span class="dot @Dot(machine.Status)"></span>
                    <span class="mono fleet-name">@machine.Name</span>
                    @if (machine.FrontDoor)
                    {
                        <span class="chip">front door</span>
                    }
                    <span class="spacer"></span>
                    <span class="mono fleet-version">@(machine.Version is not null ? $"v{machine.Version}" : "−")</span>
                </div>
                <div class="fleet-bottom">
                    <div class="fleet-sub">
                        @if (machine.Status == AgentConnectionStatus.Connected)
                        {
                            <span class="fleet-ok">Connected</span>
                            @foreach (var app in machine.Apps)
                            {
                                <span class="fleet-sep">|</span>
                                <span class="mono fleet-app">@app</span>
                            }
                        }
                        else if (machine.Status == AgentConnectionStatus.Pending)
                        {
                            <span class="fleet-pending">Pending | Waiting to connect...</span>
                        }
                        else
                        {
                            <span class="fleet-down">Disconnected@(machine.LastSeen is not null ? $" | last seen {machine.LastSeen}" : "")</span>
                        }
                    </div>
                    <span class="spacer"></span>
                    @if (_isAdmin)
                    {
                        <button class="fleet-remove" @onclick="() => StartRemove(machine.Name)" disabled="@_busy">Remove</button>
                    }
                </div>
            </div>
        }
    </div>
}

@if (_enrolling)
{
    <Modal Width="md" OnClose="CloseEnroll">
        <div class="enroll">
            <div class="enroll-head">
                <h2 class="enroll-title">Add a machine</h2>
                <button class="pipe-close" @onclick="CloseEnroll" aria-label="Close">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="m6 6 12 12M18 6 6 18" /></svg>
                </button>
            </div>

            @if (_minted is null)
            {
                <label class="field">
                    <span class="field-label">Name</span>
                    <input class="input mono" @bind="_enrollName" @bind:event="oninput" placeholder="e.g. hetzner-fsn1" />
                </label>
                @if (_enrollError is not null)
                {
                    <div class="trigger-error">@_enrollError</div>
                }
                <div class="confirm-actions">
                    <button class="btn btn-ghost" @onclick="CloseEnroll">Cancel</button>
                    <button class="btn btn-primary" @onclick="Mint" disabled="@(_busy || string.IsNullOrWhiteSpace(_enrollName))">Create token</button>
                </div>
            }
            else
            {
                <p class="enroll-lede">
                    Run this on <span class="mono">@_minted.Name</span> to install the agent. The token is shown <b>once</b>.
                </p>
                <div class="enroll-oneliner">
                    <pre class="enroll-cmd"><code>@_joinCommand</code></pre>
                    <button class="btn btn-ghost btn-sm enroll-copy" @onclick="CopyJoinCommand">@(_copied ? "Copied" : "Copy")</button>
                </div>
                <p class="enroll-hint">Linux; drop <span class="mono">sudo</span> on macOS. Prefer to run the container yourself? Set these:</p>
                <pre class="enroll-cmd"><code>Agent__Name=@_minted.Name
Agent__EnrollmentSecret=@_minted.Token
Agent__ServerAddress=@_agentLinkAddress
Agent__ServerPin=@_agentLinkPin</code></pre>

                <div class="enroll-wait">
                    @if (_connected)
                    {
                        <span class="dot dot-green"></span>
                        <span class="enroll-connected"><span class="mono">@_minted.Name</span> connected</span>
                    }
                    else
                    {
                        <span class="dot dot-amber"></span>
                        <span class="enroll-waiting">Waiting for <span class="mono">@_minted.Name</span> to dial in...</span>
                    }
                </div>

                <div class="confirm-actions">
                    <button class="btn btn-primary" @onclick="CloseEnroll">Done</button>
                </div>
            }
        </div>
    </Modal>
}

@if (_removing is not null)
{
    <ConfirmDelete Name="@_removing" Verb="Remove" Busy="_busy" Error="@_removeError"
                   OnConfirm="ConfirmRemove" OnClose="CancelRemove">
        @if (_removingFrontDoor)
        {
            <div class="fd-warn">
                <b><span class="mono">@_removing</span> hosts your front door</b>, the public HTTPS entry to this
                control plane. Removing it revokes the agent's enrollment, so it can no longer manage that entry
                point and cannot rejoin without re-running the installer.
            </div>
        }
        Removes <span class="mono">@_removing</span> from the fleet. It stops receiving deploys until you enroll it again.
    </ConfirmDelete>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool _isAdmin;
    private IReadOnlyList<FleetAgent>? _fleet;
    private bool _busy;
    private IDisposable? _subscription;
    private string _serverHost = "your-control-plane";
    private string _agentLinkAddress = string.Empty;
    private string _agentLinkPin = string.Empty;

    private bool _enrolling;
    private string _enrollName = string.Empty;
    private EnrollAgentResponse? _minted;
    private bool _connected;
    private string? _enrollError;
    private string _joinCommand = string.Empty;
    private bool _copied;

    private string? _removing;
    private bool _removingFrontDoor;
    private string? _removeError;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _isAdmin = state.User.IsInRole("Admin");
        }

        _serverHost = new Uri(Navigation.BaseUri).Host;

        var server = await Sender.Send(new GetServerHandler.Request());
        _agentLinkAddress = string.IsNullOrWhiteSpace(server.AgentLinkAddress)
            ? $"https://{_serverHost}:8443"
            : server.AgentLinkAddress;
        _agentLinkPin = server.AgentLinkPin;

        _subscription = Fleet.Subscribe(OnFleetEvent);
        await Reload();
    }

    private async Task Reload() =>
        _fleet = await Sender.Send(new FleetOverviewHandler.Request());

    private Task OnFleetEvent(string agent, bool connected)
    {
        return InvokeAsync(async () =>
        {
            if (_minted?.Name == agent && connected)
            {
                _connected = true;
            }

            await Reload();
            StateHasChanged();
        });
    }

    private void StartEnroll()
    {
        _enrollName = string.Empty;
        _minted = null;
        _connected = false;
        _enrollError = null;
        _joinCommand = string.Empty;
        _copied = false;
        _enrolling = true;
    }

    private void CloseEnroll() => _enrolling = false;

    private async Task Mint()
    {
        _busy = true;
        _enrollError = null;
        try
        {
            _minted = await Sender.Send(new EnrollAgentHandler.Request(_enrollName.Trim()));
            _joinCommand = AgentJoin.BuildCommand(
                Installer.Value.Repo, _minted.Name, _agentLinkAddress, _agentLinkPin, _minted.Token);
            await Reload();
        }
        catch (LuffException exception)
        {
            _enrollError = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CopyJoinCommand()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _joinCommand);
            _copied = true;
        }
        catch (JSException)
        {
        }
    }

    private void StartRemove(string name)
    {
        _removeError = null;
        _removing = name;
        _removingFrontDoor = _fleet?.FirstOrDefault(machine => machine.Name == name)?.FrontDoor ?? false;
    }

    private void CancelRemove()
    {
        _removing = null;
        _removeError = null;
    }

    private async Task ConfirmRemove()
    {
        if (_removing is null)
        {
            return;
        }

        _busy = true;
        _removeError = null;
        try
        {
            await Sender.Send(new RemoveAgentHandler.Request(_removing));
            _removing = null;
            await Reload();
        }
        catch (LuffException exception)
        {
            _removeError = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static string Dot(AgentConnectionStatus status) => status switch
    {
        AgentConnectionStatus.Connected => "dot-green",
        AgentConnectionStatus.Pending => "dot-amber",
        _ => "dot-red",
    };

    private static string? CardClass(AgentConnectionStatus status) => status switch
    {
        AgentConnectionStatus.Pending => "is-pending",
        AgentConnectionStatus.Connected => null,
        _ => "is-down",
    };

    public void Dispose() => _subscription?.Dispose();
}
