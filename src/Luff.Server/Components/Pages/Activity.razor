@page "/activity"
@attribute [Authorize]
@inject IScopedSender Sender
@inject TimeProvider Time

<PageTitle>Activity - Luff</PageTitle>

<div class="page-head">
    <BrandMark class="mobile-only" />
    <h1 class="page-title">Activity</h1>
    <span class="spacer"></span>
    <AvatarMenu />
</div>

@if (_rows is null)
{
    <div class="eyebrow act-loading">Loading...</div>
}
else if (_rows.Count == 0)
{
    <div class="cfg-empty">No activity yet.</div>
}
else
{
    <div class="act-list">
        @foreach (var row in _rows)
        {
            <div class="card act-card">
                <div class="act-top">
                    <span class="dot @Dot(row.Kind)"></span>
                    @if (row.App is not null)
                    {
                        <a class="app-link" href="apps/@row.App/activity">@row.Title</a>
                    }
                    else
                    {
                        <span class="act-title">@row.Title</span>
                    }
                    <span class="spacer"></span>
                    <span class="act-when">@When(row)</span>
                </div>
                <div class="act-foot">
                    <span class="act-detail">@row.Message</span>
                    <span class="spacer"></span>
                    <span class="act-actor mono">@row.Actor</span>
                </div>
            </div>
        }
    </div>
}

@code {
    private IReadOnlyList<AuditEventResponse>? _rows;

    protected override async Task OnInitializedAsync()
    {
        _rows = await Sender.Send(new ListAuditHandler.Request());
    }

    private string When(AuditEventResponse row) => AppHealth.Relative(Time.GetUtcNow() - row.CreatedAt);

    private static string Dot(AuditEventKind kind)
    {
        return kind switch
        {
            AuditEventKind.DeploySucceeded or AuditEventKind.AgentConnected or AuditEventKind.AppStarted
                or AuditEventKind.ServerStarted or AuditEventKind.TwoFactorEnabled => "dot-green",
            AuditEventKind.DeployFailed or AuditEventKind.AgentDisconnected => "dot-red",
            AuditEventKind.AppUnhealthy or AuditEventKind.TwoFactorDisabled => "dot-amber",
            _ => "dot-neutral",
        };
    }
}
