@page "/registries"
@attribute [Authorize]
@inject IScopedSender Sender

<PageTitle>Registries - Luff</PageTitle>

<div class="page-head">
    <BrandMark class="mobile-only" />
    <h1 class="page-title">Registries</h1>
    <span class="spacer"></span>
    @if (_isAdmin)
    {
        <button class="btn btn-primary btn-add" @onclick="StartAdd" aria-label="Add registry credentials">
            <svg class="mobile-only" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
            <span class="desktop-only">Add registry</span>
        </button>
    }
    <AvatarMenu />
</div>

@if (!_isAdmin)
{
    <div class="cfg-empty">Registries are managed by admins. You're signed in as an operator.</div>
}
else if (_registries is null)
{
    <div class="eyebrow reg-loading">Loading...</div>
}
else
{
    <div class="reg-body">
        @if (_registries.Count > 0)
        {
            <div class="reg-list">
                @foreach (var registry in _registries)
                {
                    <div class="card reg-card">
                        <div class="reg-top">
                            <span class="mono reg-host">@registry.Host</span>
                            <span class="spacer"></span>
                            <button class="reg-remove" @onclick="() => StartRemove(registry.Host)" disabled="@_busy">Remove</button>
                        </div>
                        <div class="reg-sub mono">
                            <span class="reg-user">@registry.Username</span>
                        </div>
                        <div class="reg-secret">
                            <span class="reg-secret-label">Password</span>
                            <SecretField Value="@registry.Password" ReadOnly="true" />
                        </div>
                        <span class="reg-matches mono">matches @registry.Host/*</span>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="cfg-empty">No Docker registries.</div>
        }

        @if (_error is not null)
        {
            <div class="cfg-error">@_error</div>
        }

        @if (_adding)
        {
            <div class="card reg-add">
                <input class="input mono" placeholder="host (e.g. ghcr.io)" @bind="_host" />
                <input class="input mono" placeholder="username" @bind="_username" autocomplete="off" />
                <div class="reg-add-field">
                    <SecretField @bind-Value="_password" Placeholder="password" />
                </div>
                <button class="btn btn-primary" @onclick="Add"
                        disabled="@(_busy || string.IsNullOrWhiteSpace(_host) || string.IsNullOrWhiteSpace(_username))">Add</button>
                <button class="btn btn-ghost" @onclick="() => _adding = false">Cancel</button>
            </div>
        }
    </div>

    @if (_removing is not null)
    {
        <ConfirmDelete Name="@_removing" Verb="Remove" Busy="_busy" Error="@_removeError"
                       OnConfirm="ConfirmRemove" OnClose="CancelRemove">
            Removes the stored credentials for <span class="mono">@_removing</span>. Deploys that pull private images from it will fail until you add them again.
        </ConfirmDelete>
    }
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool _isAdmin;
    private IReadOnlyList<RegistryResponse>? _registries;
    private bool _adding;
    private string _host = string.Empty;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private bool _busy;
    private string? _error;
    private string? _removing;
    private string? _removeError;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _isAdmin = state.User.IsInRole("Admin");
        }

        if (_isAdmin)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync() =>
        _registries = await Sender.Send(new ListRegistriesHandler.Request());

    private void StartAdd()
    {
        _host = string.Empty;
        _username = string.Empty;
        _password = string.Empty;
        _error = null;
        _adding = true;
    }

    private async Task Add()
    {
        _busy = true;
        _error = null;
        try
        {
            await Sender.Send(new AddRegistryHandler.Request(_host.Trim(), _username.Trim(), _password));
            _adding = false;
            await LoadAsync();
        }
        catch (LuffException exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void StartRemove(string host)
    {
        _removing = host;
        _removeError = null;
    }

    private void CancelRemove()
    {
        _removing = null;
        _removeError = null;
    }

    private async Task ConfirmRemove()
    {
        if (_removing is null)
        {
            return;
        }

        _busy = true;
        _removeError = null;
        try
        {
            await Sender.Send(new RemoveRegistryHandler.Request(_removing));
            _removing = null;
            await LoadAsync();
        }
        catch (LuffException exception)
        {
            _removeError = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
